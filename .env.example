FAMILY_VAULT_DATABASE_URL=sqlite:///./family_vault.db
FAMILY_VAULT_REDIS_URL=redis://redis:6379/0
FAMILY_VAULT_CELERY_TASK_ALWAYS_EAGER=0
FAMILY_VAULT_AUTO_CREATE_SCHEMA=1
FAMILY_VAULT_INGESTION_RETRY_MAX_RETRIES=2
FAMILY_VAULT_INGESTION_RETRY_BASE_DELAY_SEC=5
FAMILY_VAULT_INGESTION_ALLOWED_EXTENSIONS=["pdf","docx","txt","md","xlsx"]
FAMILY_VAULT_NAS_ALLOWED_EXTENSIONS=["pdf","doc","docx","xls","xlsx","jpg","jpeg","png","webp","tif","tiff","heic"]
FAMILY_VAULT_INGESTION_SCAN_EXCLUDE_DIRS=[".git","@eadir","#recycle","$$recycle.bin","node_modules","__pycache__","mail_attachments"]
FAMILY_VAULT_INGESTION_SCAN_MAX_FILES_PER_RUN=5000
FAMILY_VAULT_INGESTION_OCR_FALLBACK_ENABLED=1
FAMILY_VAULT_INGESTION_OCR_PDF_MAX_PAGES=8
FAMILY_VAULT_INGESTION_OCR_RENDER_DPI=180
FAMILY_VAULT_INGESTION_METADATA_FALLBACK_ENABLED=1
FAMILY_VAULT_PHOTO_FILE_EXTENSIONS=["jpg","jpeg","png","webp","tif","tiff","heic"]
FAMILY_VAULT_PHOTO_MAX_SIZE_MB=20
FAMILY_VAULT_INGESTION_PHASH_DEDUP_ENABLED=1
FAMILY_VAULT_INGESTION_PHASH_HAMMING_THRESHOLD=8

FAMILY_VAULT_QDRANT_ENABLE=1
FAMILY_VAULT_QDRANT_URL=http://qdrant:6333
FAMILY_VAULT_QDRANT_COLLECTION=fkv_docs_v1
FAMILY_VAULT_QDRANT_VECTOR_SIZE=1024

FAMILY_VAULT_NAS_DEFAULT_SOURCE_DIR=/volume1/Family_Archives
FAMILY_VAULT_NAS_AUTO_SCAN_ENABLED=0
FAMILY_VAULT_NAS_SCAN_INTERVAL_SEC=900

FAMILY_VAULT_MAIL_POLL_ENABLED=0
FAMILY_VAULT_MAIL_POLL_INTERVAL_SEC=300
FAMILY_VAULT_MAIL_QUERY=has:attachment newer_than:30d
FAMILY_VAULT_MAIL_MAX_RESULTS=20
FAMILY_VAULT_MAIL_CREDENTIALS_PATH=/app/secrets/gmail/credentials.json
FAMILY_VAULT_MAIL_TOKEN_PATH=/app/secrets/gmail/token.json
FAMILY_VAULT_MAIL_ATTACHMENT_ROOT=/volume1/Family_Archives/mail_attachments
FAMILY_VAULT_MAIL_ALLOWED_EXTENSIONS=["pdf","doc","docx","xls","xlsx","jpg","jpeg","png","webp","tif","tiff","heic"]
FAMILY_VAULT_MAIL_REQUIRE_ATTACHMENT_DISPOSITION=1
FAMILY_VAULT_MAIL_SKIP_INLINE_IMAGES=1
FAMILY_VAULT_MAIL_INLINE_NAME_PATTERNS=image\\d{3,4}|logo|signature|smime
FAMILY_VAULT_TAG_RULES_PATH=/app/services/kb-worker/config/tag_rules.json

FAMILY_VAULT_OLLAMA_BASE_URL=http://ollama:11434
FAMILY_VAULT_PLANNER_MODEL=qwen3:1.7b
FAMILY_VAULT_SYNTHESIZER_MODEL=qwen3:4b-instruct
FAMILY_VAULT_EMBED_MODEL=qwen3-embedding:0.6b
FAMILY_VAULT_SUMMARY_MODEL=qwen3:4b-instruct
FAMILY_VAULT_CATEGORY_MODEL=qwen3:4b-instruct
FAMILY_VAULT_FRIENDLY_NAME_MODEL=qwen3:4b-instruct
FAMILY_VAULT_AGENT_SYNTH_TIMEOUT_SEC=20
FAMILY_VAULT_AGENT_CONTEXT_MODE=smart_followup
FAMILY_VAULT_AGENT_CONVERSATION_MAX_TURNS=2
FAMILY_VAULT_LONGDOC_PAGE_HARD_LIMIT=180
FAMILY_VAULT_LONGDOC_SAMPLE_TRIGGER_PAGES=120
FAMILY_VAULT_LONGDOC_FINAL_SECTION_MAX=18
FAMILY_VAULT_LONGDOC_FINAL_SEMANTIC_MAX=6

NEXT_PUBLIC_FKV_API_BASE=/api
FKV_INTERNAL_API_BASE=http://fkv-api:18080
